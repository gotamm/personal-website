---
interface Props {
    href: string;
    src: string;
    alt: string;
}

const { href, src, alt } = Astro.props;
---

<style>
    a {
        display: inline-block;
        border-radius: 100%;
        height: 32px;
        width: 32px;
        background-color: var(--blue);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity ease-in-out 100ms;

        &:hover {
            opacity: 0.8;
        }
    }

    img {
        height: 20px;
        width: 20px;
    }
</style>
<a target="_blank" href={href}>
    <img
        src={src}
        alt={alt}
        height="26"
        width="26"
        style="fill: white;"
        loading="lazy"
    />
</a>
